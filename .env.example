# ── Local development ────────────────────────────────────────────────────────

# Amazon.in login — email/phone + password.
# IMPORTANT: The very first local run MUST be headed (--headed=true) so you can
# manually clear any captcha or device-verification challenge Amazon throws at a
# fresh browser. After that, auth_state.json persists the session.
AMAZON_USERNAME=your_email_or_phone@example.com
AMAZON_PASSWORD=your_amazon_password

# ── Render / cloud deployment (add these in Render dashboard → Environment) ──

# Paste the full contents of auth_state.json here after the first successful
# local scrape. The app logs this value to stdout automatically after each
# scrape so you can refresh it when needed.
AMAZON_AUTH_STATE=

# How many recent Amazon Fresh orders to scrape by default. Used by both the
# CLI (when --orders isn't passed) and the Flask /api/products POST (when the
# request body omits "orders"). Explicit values still override this.
ORDERS_TO_SCRAPE=10

# ── Salesforce sync (optional) ───────────────────────────────────────────────
# When all four SF_* vars are set, after every successful scrape each unique
# product is pushed to Salesforce: Grocery_Product__c records are matched by
# title__c, then number_of_times_purchased__c, last_ordered_date__c, and
# source__c (= "Amazon") are updated. Titles with no matching record are
# logged and skipped — new Grocery_Product__c records are NEVER created.
# Uses OAuth 2.0 client_credentials against a Salesforce Connected App.

SF_TOKEN_URL=https://<your-domain>.my.salesforce.com/services/oauth2/token
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_ENDPOINT=https://<your-domain>.my.salesforce.com/services/data/v57.0/sobjects/Grocery_Product__c/
