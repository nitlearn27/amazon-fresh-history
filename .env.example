# ── Local development ────────────────────────────────────────────────────────

# Amazon.in login — email/phone + password.
AMAZON_USERNAME=your_email_or_phone@example.com
AMAZON_PASSWORD=your_amazon_password

# How many recent Amazon Fresh orders to scrape by default. Used by both the
# CLI (when --orders isn't passed) and the Flask /api/products POST (when the
# request body omits "orders"). Explicit values still override this.
ORDERS_TO_SCRAPE=10

# Delivery location set after login so Amazon Fresh product pages report correct
# availability/price (Fresh availability is per-location; with none set, items
# show "currently unavailable" and no price). The scraper first tries to pick the
# saved address whose text contains DELIVERY_ADDRESS_PREFIX, and only falls back
# to entering DELIVERY_PINCODE (6 digits) if that address can't be found.
#
# These are PERSONAL — fill them in your own .env (or the Render/Railway
# dashboard); never commit real values. Examples (replace with your own):
#   DELIVERY_ADDRESS_PREFIX=12, Flat No 3      # a substring of your saved address
#   DELIVERY_PINCODE=110001                    # your 6-digit delivery pincode
DELIVERY_ADDRESS_PREFIX=
DELIVERY_PINCODE=

# Session caching (OPT-IN, default off): when enabled, the session is saved to
# auth_state.json after login and reused so later runs skip login/OTP. Off by
# default so cloud deploys keep the proven full-login behavior (their ephemeral
# filesystem wouldn't persist the file across restarts anyway).
#   AMAZON_SESSION_REUSE   — set to true to enable reuse (default false).
#   AMAZON_AUTH_STATE_PATH — override the storage_state file location.
# auth_state.json holds live session cookies — it's gitignored; never commit it.
# AMAZON_SESSION_REUSE=true
# AMAZON_AUTH_STATE_PATH=auth_state.json

# 2-step verification OTP: when Amazon asks for a code, the run blocks waiting
# for you to POST it to /api/otp. OTP_TTL_SECONDS sets how long a pushed code
# stays valid (default 300 = 5 min); it is also cleared the instant it is used.
# OTP_TTL_SECONDS=300

# ── Agentic self-healing (optional, DeepSeek) ───────────────────────────────
# When an automation step fails on something an LLM can figure out from the
# page (e.g. an Add button that is really a size-variant control), the app asks
# DeepSeek for a recovery recipe, applies it, and saves it to skills.json so
# the next occurrence is handled instantly without an LLM call. Disabled when
# DEEPSEEK_API_KEY is unset — everything then behaves exactly as before.
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# AGENT_ENABLED=true            # set false to disable without removing the key
# SKILLS_PATH=skills.json       # where learned skills are persisted

# ── Salesforce sync (optional product sync) ─────────────────────────────────
# All four SF_* vars are needed for product sync: after each scrape, matching
# Grocery_Product__c records are updated. Titles with no matching record are
# skipped; no new records are ever created.
# If any SF_* var is missing, sync is disabled (the scrape still runs).

SF_TOKEN_URL=https://<your-domain>.my.salesforce.com/services/oauth2/token
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_ENDPOINT=https://<your-domain>.my.salesforce.com/services/data/v57.0/sobjects/Grocery_Product__c/
