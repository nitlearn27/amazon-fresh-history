# ── Local development ────────────────────────────────────────────────────────

# Amazon.in login — email/phone + password.
AMAZON_USERNAME=your_email_or_phone@example.com
AMAZON_PASSWORD=your_amazon_password

# How many recent Amazon Fresh orders to scrape by default. Used by both the
# CLI (when --orders isn't passed) and the Flask /api/products POST (when the
# request body omits "orders"). Explicit values still override this.
ORDERS_TO_SCRAPE=10

# Delivery location set after login so Amazon Fresh product pages report correct
# availability/price (Fresh availability is per-location; with none set, items
# show "currently unavailable" and no price). The scraper first tries to pick the
# saved address whose text contains DELIVERY_ADDRESS_PREFIX, and only falls back
# to entering DELIVERY_PINCODE (6 digits) if that address can't be found.
DELIVERY_ADDRESS_PREFIX=82, Flat No 6
DELIVERY_PINCODE=560094

# ── Salesforce sync (required for OTP + optional product sync) ───────────────
# All four SF_* vars are needed for:
#   • OTP bridge — scraper polls Purchase_Info__c.my_amazon_otp__c for the
#     2-step verification code (both local and Render runs).
#   • Product sync — after each scrape, matching Grocery_Product__c records
#     are updated. Titles with no matching record are skipped; no new records
#     are ever created.
# If any SF_* var is missing, both OTP polling and sync are disabled.

SF_TOKEN_URL=https://<your-domain>.my.salesforce.com/services/oauth2/token
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_ENDPOINT=https://<your-domain>.my.salesforce.com/services/data/v57.0/sobjects/Grocery_Product__c/
